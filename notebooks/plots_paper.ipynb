    "            use_percentile = True\n",
    "            if use_percentile==True:\n",
    "                mean_predtotrue = np.median(e_over_true)\n",
    "                p16 = np.percentile(e_over_true, 16)\n",
    "                p84 = np.percentile(e_over_true, 84)\n",
    "                var_predtotrue = p84 - p16\n",
    "            else:\n",
    "\n",
